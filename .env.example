# ── Backend ──────────────────────────────────────────────────────────────────

# GenLayer Studionet RPC endpoint
GENLAYER_RPC_URL=http://localhost:4000/api
GENLAYER_CHAIN_ID=61999

# Deployed contract addresses
MARKETPLACE_CONTRACT_ADDRESS=0x
JUDGE_CONTRACT_ADDRESS=0x

# Backend service wallet — signs JudgeContract.evaluate() transactions
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKEND_PRIVATE_KEY=0x

# Pinata IPFS
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Master key for wrapping per-listing encryption keys (AES-256-GCM)
# Must be exactly 32 bytes, base64-encoded
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# PostgreSQL connection string (used by the pg driver)
DATABASE_URL=postgres://user:password@localhost:5432/genmarket

# Express port
PORT=4000

# ── Frontend (.env.local) ─────────────────────────────────────────────────────

# Exposed to the browser — prefix with NEXT_PUBLIC_
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=0x
NEXT_PUBLIC_JUDGE_CONTRACT_ADDRESS=0x
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Internal backend URL used by Next.js server (rewrites + API routes)
BACKEND_URL=http://localhost:4000
